# Server Configuration
PORT=3001

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Alpha Vantage Stock API
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Firebase Admin SDK (Private)
# You can use the raw JSON string OR a Base64 encoded string of the JSON.
# Base64 is highly recommended for Render to avoid line-break parsing issues.
FIREBASE_SERVICE_ACCOUNT_KEY=your_firebase_service_account_base64_string
